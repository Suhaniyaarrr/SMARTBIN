# Server Port
PORT=5000

# Optional shared secret for write endpoints (/api/bin-data and /api/update-bin)
SMARTBIN_API_KEY=change_me_before_deploying

# Optional rate limit for update endpoints
UPDATE_RATE_LIMIT_WINDOW_MS=60000
UPDATE_RATE_LIMIT_MAX=30

# Frontend origin allowed by CORS (use your deployed frontend URL in production)
FRONTEND_ORIGIN=http://localhost:3000

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
ALERT_RECIPIENT_NUMBER=+0987654321
