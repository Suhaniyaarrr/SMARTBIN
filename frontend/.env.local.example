# Backend base URL for local/dev dashboards
# Leave blank to use Next.js rewrites and same-origin /api calls
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: comma-separated extra dev origins to allow HMR requests from LAN/IP hosts
# Example: http://192.168.1.20:3000,http://10.0.0.50:3000
NEXT_ALLOWED_DEV_ORIGINS=
